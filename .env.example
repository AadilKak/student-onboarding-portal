# Where the frontend finds the backend API.
# Local on one machine:        leave unset (defaults to http://localhost:5000)
# Testing across your network:  set to the HOST computer's LAN IP, e.g.
# VITE_API_URL=http://192.168.1.50:5000
# Deployed (Vercel):            set to your Render URL, e.g.
# VITE_API_URL=https://al-huda-api.onrender.com
